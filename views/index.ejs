<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Loja</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
    <div class="container">
        <div class="row">
            <% products.forEach(p => { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <img src="<%= p.fotoUrl %>" class="card-img-top" style="height: 200px; object-fit:cover;" alt="Produto">
                        <div class="card-body">
                            <h5 class="card-title"><%= p.nome %></h5>
                            <p class="card-text text-muted"><%= p.marca %> - <%= p.modelo %></p>
                            <h6 class="text-success">R$ <%= p.preco.toFixed(2) %></h6>
                            <small class="text-muted">Estoque: <%= p.quantidade %></small>
                        </div>
                        <div class="card-footer">
                            <form action="/cart/add/<%= p.rowKey %>" method="POST">
                                <button class="btn btn-primary w-100">Adicionar ao Carrinho</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>