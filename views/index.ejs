<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-3 gap-2">
    <h2 class="section-title mb-0">Nossos Produtos</h2>
    <span class="muted"><%= products.length %> item(ns) encontrado(s)</span>
</div>

<!-- Filtros -->
<div class="page-card p-3 p-md-4 mb-4">
    <form action="/" method="GET" class="row g-3">
        <div class="col-12 col-md-4 col-lg-3">
            <input type="text" name="search" class="form-control" placeholder="Buscar..." value="<%= query.search %>">
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <input type="text" name="marca" class="form-control" placeholder="Marca" value="<%= query.marca %>">
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <input type="number" name="minPrice" class="form-control" placeholder="Min R$" step="0.01" value="<%= query.minPrice %>">
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <input type="number" name="maxPrice" class="form-control" placeholder="Max R$" step="0.01" value="<%= query.maxPrice %>">
        </div>
        <div class="col-6 col-md-4 col-lg-3 d-grid">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>
</div>

<div class="row g-4">
    <% products.forEach(p => { %>
    <div class="col-12 col-sm-6 col-lg-4">
        <div class="card page-card h-100">
            <img src="<%= p.imageUrl %>" class="card-img-top product-thumb" alt="<%= p.nome %>">
            <div class="card-body">
                <h5 class="card-title"><%= p.nome %></h5>
                <p class="card-text text-truncate muted"><%= p.descricao %></p>
                <p class="card-text"><small class="text-muted"><%= p.marca %> - <%= p.modelo %></small></p>
                <h4 class="mb-0">R$ <%= p.preco.toFixed(2) %></h4>
            </div>
            <div class="card-footer bg-white border-top-0">
                <form action="/cart/add" method="POST">
                    <input type="hidden" name="productId" value="<%= p.rowKey %>">
                    <input type="hidden" name="partitionKey" value="<%= p.partitionKey %>">
                    <button type="submit" class="btn btn-success w-100" <%= p.quantidade <= 0 ? 'disabled' : '' %>>
                        <%= p.quantidade > 0 ? 'Adicionar ao Carrinho' : 'Esgotado' %>
                    </button>
                </form>
            </div>
        </div>
    </div>
    <% }); %>
</div>