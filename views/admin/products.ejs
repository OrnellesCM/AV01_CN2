
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="section-title">GERENCIAMENTO DOS PRODUTOS</h2>
    <a href="/" class="btn btn-outline-secondary btn-sm">Voltar para loja</a>
</div>
<!-- Formulário de Cadastro -->
<div class="card page-card mb-4">
    <div class="card-header">Cadastrar Novo Produto</div>
    <div class="card-body">
        <form action="/admin/products/create" method="POST" enctype="multipart/form-data">
            <div class="row g-2">
                <div class="col-12 col-md-6 col-lg-3"><input type="text" name="nome" class="form-control" placeholder="Nome" required></div>
                <div class="col-6 col-md-3"><input type="text" name="marca" class="form-control" placeholder="Marca" required></div>
                <div class="col-6 col-md-3"><input type="text" name="modelo" class="form-control" placeholder="Modelo" required></div>
                <div class="col-6 col-md-3"><input type="number" step="0.01" name="preco" class="form-control" placeholder="Preço" required></div>
                <div class="col-6 col-md-3"><input type="number" name="quantidade" class="form-control" placeholder="Quantidade" required></div>
                <div class="col-12 col-md-6"><textarea name="descricao" class="form-control" placeholder="Descrição"></textarea></div>
                <div class="col-12 col-md-6"><input type="file" name="photo" class="form-control" accept="image/*"></div>
                <div class="col-12 mt-2 d-grid d-md-inline-flex"><button class="btn btn-success">SALVAR</button></div>
            </div>
        </form>
    </div>
</div>

<!-- Lista de Produtos -->
<div class="page-card p-2 p-md-3">
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>Marca</th>
                    <th>Preço</th>
                    <th>Estoque</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(p => { %>
                <tr>
                    <td><img src="<%= p.imageUrl %>" width="50" alt="<%= p.nome %>"></td>
                    <td><%= p.nome %></td>
                    <td><%= p.marca %></td>
                    <td>R$ <%= p.preco.toFixed(2) %></td>
                    <td><%= p.quantidade %></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a class="btn btn-sm btn-warning" href="/admin/products/edit?partitionKey=<%= encodeURIComponent(p.partitionKey) %>&productId=<%= encodeURIComponent(p.rowKey) %>">ALTERAR</a>
                            <form action="/admin/products/delete" method="POST" onsubmit="return confirm('Excluir?')">
                                <input type="hidden" name="productId" value="<%= p.rowKey %>">
                                <input type="hidden" name="partitionKey" value="<%= p.partitionKey %>">
                                <button class="btn btn-danger btn-sm">APAGAR</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>