<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Admin Clientes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/header') %>
    <div class="container">
        <h2>Gerenciar Clientes</h2>
        <table class="table table-striped">
            <thead><tr><th>Nome</th><th>Email</th><th>Telefone</th><th>Cidade</th><th>Ações</th></tr></thead>
            <tbody>
                <% customers.forEach(c => { %>
                    <tr>
                        <td><%= c.nome %></td>
                        <td><%= c.email %></td>
                        <td><%= c.telefone %></td>
                        <td><%= c.cidade %></td>
                        <td>
                            <button class="btn btn-sm btn-info" onclick="fetch('/admin/customers/<%= c.rowKey %>/orders').then(r=>r.json()).then(d => alert('Pedidos: ' + JSON.stringify(d, null, 2)))">Ver Pedidos</button>
                            <form action="/admin/customers/delete/<%= c.rowKey %>" method="POST" style="display:inline;">
                                <button class="btn btn-sm btn-danger" onclick="confirm('Excluir cliente?')">Del</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>