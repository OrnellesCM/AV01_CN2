<h2 class="section-title">Carrinho de Compras</h2>
<% if (cart.length === 0) { %>
    <div class="alert alert-info page-card border-0">Seu carrinho está vazio.</div>
<% } else { %>
    <div class="page-card p-2 p-md-3 mb-4">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Preço</th>
                        <th>Qtd</th>
                        <th>Subtotal</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach(item => { %>
                        <tr>
                            <td><%= item.nome %></td>
                            <td>R$ <%= item.preco.toFixed(2) %></td>
                            <td><%= item.qty %></td>
                            <td>R$ <%= (item.preco * item.qty).toFixed(2) %></td>
                            <td>
                                <form action="/cart/update" method="POST" class="d-inline-flex gap-1">
                                    <input type="hidden" name="productId" value="<%= item.rowKey %>">
                                    <button name="action" value="inc" class="btn btn-sm btn-outline-secondary">+</button>
                                    <button name="action" value="dec" class="btn btn-sm btn-outline-secondary">-</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end"><strong>Total:</strong></td>
                        <td colspan="2"><strong>R$ <%= total.toFixed(2) %></strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="page-card p-3 p-md-4">
        <h4 class="mb-3">Finalizar Pedido</h4>
        <form action="/checkout" method="POST">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Email (Identificação)</label>
                    <input type="email" name="customerEmail" class="form-control" required placeholder="seu@email.com">
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Tipo de Entrega</label>
                    <select name="deliveryMethod" class="form-select">
                        <option value="sedex">SEDEX</option>
                        <option value="pac">PAC</option>
                        <option value="retirada">Retirada na Loja</option>
                    </select>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Método de Pagamento</label>
                    <select name="paymentMethod" class="form-select">
                        <option value="pix">PIX</option>
                        <option value="cartao">Cartão de Crédito</option>
                        <option value="boleto">Boleto</option>
                    </select>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary btn-lg w-100">Confirmar Pedido</button>
                </div>
            </div>
        </form>
    </div>
<% } %>