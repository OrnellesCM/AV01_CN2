
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="section-title">ÁREA DO CLIENTE</h2>
    <a href="/" class="btn btn-outline-secondary btn-sm">Voltar para loja</a>
</div>
<div class="page-card p-3 p-md-4 mb-4">
    <form action="/profile" method="GET" class="row g-3">
        <div class="col-12 col-md-8">
            <input type="email" name="email" class="form-control" value="<%= email %>" placeholder="Digite seu email">
        </div>
        <div class="col-12 col-md-4 d-grid">
            <button class="btn btn-outline-primary">LISTAR MEUS PEDIDOS</button>
        </div>
    </form>
</div>

<% if (orders.length > 0) { %>
    <h4 class="mb-3">Seus Pedidos</h4>
    <div class="row g-3">
        <% orders.forEach(order => { %>
            <div class="col-12 col-lg-6">
                <div class="card page-card">
                    <div class="card-header d-flex justify-content-between">
                        <span>Pedido: <%= order.rowKey.substring(0, 8) %></span>
                        <span class="badge bg-info"><%= order.status %></span>
                    </div>
                    <div class="card-body">
                        <p><strong>Data:</strong> <%= new Date(order.date).toLocaleString() %></p>
                        <p><strong>Total:</strong> R$ <%= order.total.toFixed(2) %></p>
                        <p><strong>Entrega:</strong> <%= order.delivery %></p>
                        <p><strong>Pagamento:</strong> <%= order.payment %></p>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } else if (email) { %>
    <div class="alert alert-warning">Nenhum pedido encontrado para este email.</div>
<% } %>