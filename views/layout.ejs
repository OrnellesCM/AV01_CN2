<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Commerce Azure</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">AzureShop</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <% if (locals.user) { %>
                        <li class="nav-item"><a class="nav-link" href="/cart">Carrinho</a></li>
                        <li class="nav-item"><a class="nav-link" href="/profile">Meu Perfil</a></li>
                        <% if (user.isAdmin) { %>
                            <li class="nav-item"><a class="nav-link" href="/admin/products">Admin Produtos</a></li>
                            <li class="nav-item"><a class="nav-link" href="/admin/customers">Admin Clientes</a></li>
                        <% } %>
                        <li class="nav-item"><a class="nav-link" href="/logout">Sair</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/register">Cadastrar</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        <%= body %>
    </div>
</body>
</html>