<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loja Ornelles</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --brand-primary: #2563eb;
            --surface-bg: #f8fafc;
            --text-strong: #0f172a;
            --text-soft: #475569;
        }

        body {
            padding-top: 76px;
            background: var(--surface-bg);
            color: var(--text-strong);
        }

        .app-shell {
            max-width: 1200px;
        }

        .brand-pill {
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .page-card {
            border: 1px solid #e2e8f0;
            border-radius: 0.9rem;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
            background: #fff;
        }

        .section-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .muted {
            color: var(--text-soft);
        }

        .product-thumb {
            height: 220px;
            object-fit: cover;
        }

        .table thead th {
            white-space: nowrap;
        }

        .navbar .nav-link.active {
            color: #fff;
            font-weight: 600;
        }

        @media (max-width: 767.98px) {
            body {
                padding-top: 68px;
            }

            .product-thumb {
                height: 180px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand brand-pill" href="/"></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Alternar navegação">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link <%= (typeof currentPath !== 'undefined' && currentPath === '/') ? 'active' : '' %>" href="/">LOJA</a></li>
                    <li class="nav-item"><a class="nav-link <%= (typeof currentPath !== 'undefined' && currentPath.startsWith('/cart')) ? 'active' : '' %>" href="/cart">CARRINHO</a></li>
                    <li class="nav-item"><a class="nav-link <%= (typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/products')) ? 'active' : '' %>" href="/admin/products">PRODUTOS</a></li>
                    <li class="nav-item"><a class="nav-link <%= (typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/customers')) ? 'active' : '' %>" href="/admin/customers">CLIENTES</a></li>
                </ul>
                <a class="btn btn-outline-light btn-sm mt-3 mt-lg-0" href="/profile">Minha Conta</a>
            </div>
        </div>
    </nav>
    <div class="container app-shell mt-3 mt-md-4">
        <% if (typeof notice !== 'undefined' && notice) { %>
            <div class="alert alert-<%= noticeType %> alert-dismissible fade show" role="alert">
                <%= notice %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        <% } %>
        <%- body %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>